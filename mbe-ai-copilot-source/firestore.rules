rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // users/{uid} and companies/{uid} — a user can only read/write their own docs.
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }
    match /companies/{uid} {
      allow read, write: if isOwner(uid);
    }

    // assessments/{uid}/entries/{entryId} — subcolección real (4 segmentos de
    // ruta). El patrón anterior, assessments/{uid}/{assessmentId} (3
    // segmentos), no resuelve a un documento válido en Firestore, así que
    // cualquier escritura ahí habría sido denegada en silencio.
    match /assessments/{uid}/entries/{entryId} {
      allow read, write: if isOwner(uid);
    }

    // sessions/{sessionId} — chat sessions carry uid as a field, not as the doc id.
    //
    // BUG FIX (Fase 3 / Babel AI): getOrCreateBabelSession() always calls
    // getDoc() BEFORE the document exists (to decide whether to create it).
    // On a nonexistent doc, `resource` is null, so `resource.data.uid` throws
    // and Firestore denies the read — the client never gets the chance to
    // create the session. `resource == null || ...` short-circuits that.
    match /sessions/{sessionId} {
      allow get: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // deliverables/{deliverableId} — same pattern as sessions.
    match /deliverables/{deliverableId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    // phds/{id} — RAG knowledge base, read-only for authenticated users, written only by admin (Cloud Functions with the Admin SDK bypass rules entirely).
    match /phds/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
